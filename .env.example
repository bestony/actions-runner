REPO=<owner>/<repo>
TOKEN=<your-github-runner-registration-token>
ACTIONS_RESULTS_URL=http://cache:3000/

# Optional runner settings
RUNNER_NAME=
RUNNER_LABELS=
RUNNER_WORKDIR=_work
RUNNER_REPLICAS=4

# Optional resource settings used by docker-compose.yml
RUNNER_RESERVED_CPUS=0.5
RUNNER_RESERVED_MEMORY=1024M
RUNNER_LIMIT_CPUS=2.0
RUNNER_LIMIT_MEMORY=4096M
